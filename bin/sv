#!/bin/bash -e

clean() {
  (cd docs && rm -fr _site Gemfile.lock .jekyll-metadata)
}

up() {
  (cd container && podman-compose up -d)
}

logs() {
  podman logs -n 100 -f blog_web_1
}

down() {
  (cd container && podman-compose down)
}

build() {
  (cd container && podman-compose build --no-cache)
}

base_dir=$(cd $(dirname ${BASH_SOURCE:-$0})/.. && pwd)
cd $base_dir

if [[ ! -e "docs/index.md" ]]; then
  echo "wrong dir!" >&2
  exit 1
fi

for word in $*; do
  $word
done
